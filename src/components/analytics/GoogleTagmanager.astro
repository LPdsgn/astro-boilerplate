---
import { SITE } from '@/site.config';
---

{
	SITE.analytics?.gtmId && (
		<>
			{/* GTM bootstrap — inline, gated by cookie consent */}
			<script
				is:inline
				define:vars={{ GTM_ID: SITE.analytics.gtmId }}
				type="text/plain"
				data-category="analytics"
				data-service="Google Analytics"
			>
				(function (w, d, s, l, i) {
					w[l] = w[l] || [];
					w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
					var f = d.getElementsByTagName(s)[0],
						j = d.createElement(s),
						dl = l != 'dataLayer' ? '&l=' + l : '';
					j.async = true;
					j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
					f.parentNode.insertBefore(j, f);
				})(window, document, 'script', 'dataLayer', GTM_ID);

				function trackPageview() {
					if (typeof window.dataLayer !== 'object') return;

					const url = window.location.pathname + window.location.search;
					const title = document.title;

					window.dataLayer.push({
						event: 'VirtualPageview',
						virtualPageURL: url,
						virtualPageTitle: title,
					});

					console.log('[GTM] Pageview:', url);
				}

				trackPageview();
				document.addEventListener('swup:page:view', trackPageview);
			</script>
		</>
	)
}
