---
import type { HTMLAttributes } from 'astro/types';
import { tv } from 'tailwind-variants';

type Props = HTMLAttributes<'dialog'> & {
	/**
	 * Open and close animation duration in milliseconds
	 */
	animationDuration?: number;
};

export const alertDialogBackdrop = tv({
	base: [
		'c-alert-dialog-backdrop fixed inset-0 z-50 hidden bg-black/50',
		'fade-in data-[state=open]:animate-in',
		'fade-out data-[state=closed]:animate-out data-[state=closed]:fill-mode-forwards',
	],
});

export const alertDialogContent = tv({
	base: [
		'space-y-4 rounded-lg border bg-background p-6 shadow-lg sm:max-w-lg',
		'fixed top-[50%] left-[50%] z-50 w-full max-w-[calc(100%-2rem)] translate-x-[-50%] translate-y-[-50%]',
		'will-change-transform zoom-in-95 fade-in data-[state=open]:animate-in',
		'zoom-out-95 fade-out data-[state=closed]:animate-out data-[state=closed]:fill-mode-forwards',
	],
});

const { class: className, animationDuration = 200, ...rest } = Astro.props;
---

<!-- dialog overlay -->
<slot name="backdrop">
	<div
		class={alertDialogBackdrop()}
		data-state="closed"
		data-slot="alert-dialog-backdrop"
		style={{ animationDuration: `${animationDuration}ms` }}
	>
	</div>
</slot>

<dialog
	class={alertDialogContent({ class: className })}
	data-state="closed"
	data-slot="alert-dialog-content"
	role="alertdialog"
	{...rest}
	style={{ animationDuration: `${animationDuration}ms` }}
>
	<slot />
</dialog>
