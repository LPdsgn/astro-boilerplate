{
	"name": "@lpdsgn/astro-boilerplate",
	"title": "Astro Project Boilerplate",
	"type": "module",
	"version": "1.0.0",
	"engines": {
		"node": "22.x || 24.x"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/lpdsgn/astro-boilerplate.git"
	},
	"author": {
		"name": "Luigi Pedata",
		"email": "luigi@lpdsgn.it",
		"homepage": "https://lpdsgn.it"
	},
	"imports": {
		"#styles": "./src/styles/main.css"
	},
	"scripts": {
		"prepare": "simple-git-hooks",
		"dev": "astro dev --host",
		"start": "astro dev --host",
		"check": "astro check",
		"build": "astro check && astro build",
		"build:debug": "astro check && astro build 2>&1 | grep -E \"\\[ERROR\\]|\\[vite\\]|Cannot apply unknown|Could not resolve|Can't resolve|Unable to locate|✓ Completed|Build failed|Build complete|ELIFECYCLE\"",
		"preview": "astro preview",
		"astro": "astro",
		"format": "prettier --write .",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"precommit": "pnpm lint:fix && pnpm format"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.6",
		"@astrojs/mdx": "^4.3.13",
		"@astrojs/vercel": "^9.0.4",
		"@iconify-json/carbon": "^1.2.19",
		"@iconify-json/fa6-brands": "^1.2.6",
		"@iconify-json/logos": "^1.2.10",
		"@iconify-json/lucide": "^1.2.95",
		"@iconify-json/simple-icons": "^1.2.71",
		"@locomotivemtl/grid-helper": "^1.0.0",
		"@lpdsgn/astro-themes": "^0.1.3",
		"@swup/a11y-plugin": "^5.0.0",
		"@swup/body-class-plugin": "^3.3.0",
		"@swup/debug-plugin": "^4.1.0",
		"@swup/head-plugin": "^2.3.1",
		"@swup/preload-plugin": "^3.2.11",
		"@swup/progress-plugin": "^3.2.0",
		"@swup/scripts-plugin": "^2.1.0",
		"@tabler/icons": "^3.36.1",
		"@tailwindcss/forms": "^0.5.11",
		"@vercel/analytics": "^1.6.1",
		"@vercel/speed-insights": "^1.3.1",
		"animated-cursor": "^1.2.0",
		"astro": "^5.18.0",
		"astro-capo": "^0.0.1",
		"astro-embed": "^0.12.0",
		"astro-favicons": "^3.1.5",
		"astro-icon": "^1.1.5",
		"astro-meta-tags": "^0.4.0",
		"astro-seo": "^1.1.0",
		"embla-carousel": "^8.6.0",
		"gsap": "^3.14.2",
		"locomotive-scroll": "^5.0.1",
		"nanostores": "^1.1.1",
		"satori-astro": "^0.3.3",
		"satori-html": "^0.3.2",
		"sharp": "^0.34.5",
		"swup": "^4.8.3",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.1",
		"ts-debounce": "^4.0.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vanilla-cookieconsent": "^3.1.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@locomotivemtl/postcss-helpers-functions": "^1.0.4",
		"@locomotivemtl/postcss-tailwind-shortcuts": "^2.0.1",
		"@tailwindcss/postcss": "^4.2.1",
		"autoprefixer": "^10.4.27",
		"cssnano": "^7.1.2",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-astro": "^1.6.0",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-react": "^7.37.5",
		"globals": "^17.4.0",
		"lint-staged": "^16.3.1",
		"postcss-nested": "^7.0.2",
		"postcss-utopia": "^1.1.0",
		"prettier": "^3.8.1",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-astro-organize-imports": "^0.4.11",
		"prettier-plugin-tailwindcss": "^0.7.1",
		"rollup-plugin-visualizer": "^7.0.0",
		"simple-git-hooks": "^2.13.1",
		"sonda": "^0.11.1",
		"typescript-eslint": "^8.56.1",
		"vite-plugin-compression": "^0.5.1"
	},
	"simple-git-hooks": {
		"pre-commit": "npx lint-staged",
		"pre-push": "pnpm build"
	},
	"lint-staged": {
		"*.{js,mjs,cjs,ts,tsx,jsx,astro}": [
			"eslint --fix"
		],
		"*.{js,mjs,cjs,ts,tsx,jsx,astro,css,scss,json,html,yaml,yml}": [
			"prettier --write --ignore-unknown"
		]
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"sharp",
			"simple-git-hooks",
			"swup"
		],
		"overrides": {
			"tar@>=7.0.0 <7.5.8": "~7.5.8",
			"lodash@>=4.0.0 <=4.17.22": "~4.17.23",
			"devalue@>=5.0.0 <=5.6.2": "~5.6.3",
			"ajv@>=6.0.0 <6.14.0": "~6.14.0",
			"ajv@>=7.0.0-alpha.0 <8.18.0": "~8.18.0",
			"minimatch@>=3.0.0 <3.1.4": "~3.1.4",
			"minimatch@>=9.0.0 <9.0.7": "~9.0.7",
			"rollup@>=4.0.0 <4.59.0": "~4.59.0",
			"svgo@=4.0.0": ">=4.0.1",
			"svgo@>=3.0.0 <3.3.3": ">=3.3.3",
			"flatted@<3.4.0": ">=3.4.0",
			"undici@>=7.0.0 <7.24.0": ">=7.24.0",
			"undici@>=7.17.0 <7.24.0": ">=7.24.0",
			"h3@<1.15.6": ">=1.15.6",
			"flatted@<=3.4.1": ">=3.4.2",
			"h3@<1.15.9": ">=1.15.9",
			"h3@<=1.15.8": ">=1.15.9"
		}
	}
}
